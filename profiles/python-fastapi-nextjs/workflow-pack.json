{
  "project_name": "REPLACE_ME",
  "primary_product": "FastAPI backend + Next.js frontend",
  "legacy_surface": "legacy runtime retained only for compatibility",
  "artifact_dir": "specs",
  "supported_workspaces": [
    "Codex",
    "Claude Code",
    "OpenCode",
    "GitHub Copilot",
    "Antigravity"
  ],
  "coverage_threshold": 100,
  "backend_stack": [
    "Python 3.12+",
    "Poetry",
    "FastAPI",
    "Uvicorn",
    "pytest",
    "pytest-cov",
    "black",
    "flake8",
    "mypy"
  ],
  "frontend_stack": [
    "Next.js 14",
    "React 18",
    "Vitest"
  ],
  "repository_map": [
    "`src/` -> application code",
    "`tests/` -> test suite",
    "`skills/` -> canonical repo-local skills source for `/brief` and `/workflow`",
    "`.claude/skills/` -> Claude Code skill mirror",
    "`.opencode/skills/` -> OpenCode skill mirror",
    "`.agents/skills/` -> generic agent skill mirror",
    "`.specify/` -> Specify templates and constitution",
    "`.claude/commands/` -> Claude Code slash commands",
    "`.opencode/` -> OpenCode command surface",
    "`.codex/` -> Codex prompt surface",
    "`.github/agents/` -> GitHub Copilot custom agents",
    "`.github/copilot-instructions.md` -> GitHub Copilot repository instructions"
  ],
  "blocking_gates": [
    "poetry run black --check --diff --target-version py312 .",
    "poetry run pytest tests/ -v --tb=short --cov=src --cov-report=xml"
  ],
  "observational_gates": [
    "poetry run flake8 src/ tests/",
    "poetry run mypy src/"
  ],
  "frontend_validation": "cd web && npm run test",
  "required_skills": [
    "brainstorming",
    "gh-fix-ci",
    "gh-address-comments"
  ],
  "brief_artifact": "BRIEF.md",
  "local_skills_dir": "skills",
  "constitution_version": "2.0.0"
}
